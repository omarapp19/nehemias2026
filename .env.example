# ──────────────────────────────────────────────────────────────
#  Proyecto Nehemías — variables de entorno
#  Copia este archivo como `.env` y rellena los valores reales.
#  NUNCA subas el `.env` real al repositorio.
# ──────────────────────────────────────────────────────────────

# --- Base de datos (PostgreSQL) ---
# En local (pnpm dev) apunta a tu Postgres local.
# En Docker, el host es el nombre del servicio: "db".
POSTGRES_USER=nehemias
POSTGRES_PASSWORD=cambia_esta_clave
POSTGRES_DB=nehemias
DATABASE_URL=postgresql://nehemias:cambia_esta_clave@localhost:5432/nehemias?schema=public

# --- Autenticación de administradores ---
# Secreto para firmar los JWT de sesión admin. Genera uno largo y aleatorio:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=genera_un_secreto_largo_y_aleatorio
# Duración de la sesión admin
JWT_EXPIRES_IN=7d
# Dominio de la cookie (vacío en local; en prod, p. ej. .midominio.org)
COOKIE_DOMAIN=

# --- Admin inicial (lo crea el seed) ---
SEED_ADMIN_EMAIL=admin@nehemias.org
SEED_ADMIN_PASSWORD=cambia_esta_clave_admin
SEED_ADMIN_NAME=Coordinación Nehemías

# --- API (Express) ---
API_PORT=4000
# URL pública del API (la usa el navegador). En local:
NEXT_PUBLIC_API_URL=http://localhost:4000
# URL interna del API (la usa el server de Next / RSC). En Docker: http://api:4000
API_INTERNAL_URL=http://localhost:4000
# Origen permitido para CORS (el sitio web)
WEB_ORIGIN=http://localhost:3000

# --- Web (Next.js) ---
WEB_PORT=3000

# --- Almacenamiento de archivos ---
# Carpeta donde se guardan comprobantes y fotos (en Docker es un volumen montado)
UPLOADS_DIR=./uploads
# Tamaño máximo de subida en MB
MAX_UPLOAD_MB=8

# --- Entorno ---
NODE_ENV=development

# --- Enlace a Google Drive ---
# Carpeta de Google Drive para ver todas las fotos y comprobantes cargados
NEXT_PUBLIC_GOOGLE_DRIVE_FOLDER=https://drive.google.com/drive/folders/1exWkICT73WzDVtSgLOQz0mhk48xQQrGA

